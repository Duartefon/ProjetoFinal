%%________________________________________________________________________
%% para colocar, no índice, Capítulos não numerados
%%________________________________________________________________________
\newcommand{\noNumChapterInIndex}[1]
   {
   \chapter*{#1}
   \addcontentsline{toc}{chapter}{#1}
   }

\newcommand{\myPrefaceChapter}[1]
   {
   \noNumChapterInIndex{#1}
   }



%%________________________________________________________________________
%% para a dedicatória
%%________________________________________________________________________
\newenvironment{myDedication}
   {
   \chapter*{\null}
   \begin{flushright}
   \em\null\vskip1in
   }
   {
   \vfill\end{flushright}
   }



%%________________________________________________________________________
%% Para colocar as listas de conteúdos (índice, Tabelas e Figuras)
%% como entrada no índice
%%________________________________________________________________________
\newcommand{\myTableOfContents}
   {
   \chapter*{Índice\@mkboth{Conteúdo}{CONTENTS}}
   \@starttoc{toc}
   }

\newcommand{\myListOfTables}
   {
   \chapter*{Lista de Tabelas}
   \addcontentsline{toc}{chapter}{Lista de Tabelas}
   \@starttoc{lot}
   }

\newcommand{\myListOfFigures}
   {
   \chapter*{Lista de Figuras}
   \addcontentsline{toc}{chapter}{Lista de Figuras}
   \@starttoc{lof}
   }



%%________________________________________________________________________
%% Para o comando "\thebibliography" gerar uma entrada no índice
%%________________________________________________________________________
\let\@myTheBibliography\thebibliography
\renewcommand{\thebibliography}[1]
   {
   \@myTheBibliography{#1}
   \addcontentsline{toc}{chapter}{Bibliografia}
   }



%%________________________________________________________________________
%% Para definir o estilo para o cabeçalho e para a nota de rodapé
%%________________________________________________________________________
\newcommand{\myPageStyle}
   {
   \pagestyle{fancy}
   \fancypagestyle{plain}
       {
       \fancyhead{}
       \renewcommand{\headrulewidth}{0pt}
       }
   \fancyhf{}
   \fancyhead[LE,RO]{\thepage}
   \fancyhead[LO]{\nouppercase{\rightmark}}
   \fancyhead[RE]{\nouppercase{\leftmark}}
   \addtolength{\headheight}{0.5pt}
   \setlength{\headheight}{15pt}
   }



%%________________________________________________________________________
%% Renomeações para português
%%________________________________________________________________________
\addto\captionsportuguese{
    \renewcommand{\contentsname}{Índice}
    \renewcommand{\bibname}{Bibliografia}
    \renewcommand{\proofname}{Prova}
    \renewcommand{\chaptername}{Capítulo}
    \renewcommand{\appendixname}{Anexo}
    \renewcommand{\lstlistingname}{Código}
    \renewcommand{\lstlistlistingname}{Lista de Códigos}
}

\renewcommand{\chaptermark}[1]{%
  \markboth{\chaptername\ \thechapter.\ #1}{}}



